@article{HouQianNanXieQingZhongCDO1JiYinYuHOXA9JiYinQiDongZiJiaJiHuaGaoBiaoDaZaiLuanChaoAiZhenDuanZhongDeYiYi2024,
  title = {{血清中CDO1基因与HOXA9基因启动子甲基化高表达在卵巢癌诊断中的意义}},
  author = {{侯倩男} and {袁宇} and {李燕} and {龚照林} and {张强} and {冯丹} and {宫远福} and {王林海} and {刘沛} and {谢小兵} and {何丽}},
  year = 2024,
