  shorttitle = {Focused Ultrasound Ablation for Women with Cervical Lesions},
  author = {Yang, Li and Wang, Zhao-Xin and Zhu, Yuan-Hang and Bai, Yang and Liou, Yu-ligh and Li, Qian and Shi, Zhong-Na and Shi, Qiu-Ling and Ren, Chen-Chen},
